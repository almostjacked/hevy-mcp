{
  "name": "@almostjacked/hevy-mcp",
  "version": "0.1.0",
  "description": "Unofficial MCP server for Hevy — stdio + self-host worker. Bring your own Hevy PRO API key.",
  "type": "module",
  "bin": { "hevy-mcp": "dist/main.js" },
  "files": ["dist"],
  "scripts": {
    "build": "node scripts/sync-versions.mjs && tsc -p tsconfig.json",
    "prepack": "node scripts/sync-versions.mjs && tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@almostjacked/hevy-mcp-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": { "node": ">=18" },
  "license": "MIT",
  "author": "AJ Wallace <ajwallacemusic@gmail.com>",
  "repository": { "type": "git", "url": "git+https://github.com/almostjacked/hevy-mcp.git", "directory": "apps/mcp" },
  "mcpName": "io.github.almostjacked/hevy-mcp"
}
