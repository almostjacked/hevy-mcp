{
  "name": "@almostjacked/hevy-mcp",
  "version": "0.1.0",
  "description": "Unofficial MCP server for Hevy — stdio + self-host worker. Bring your own Hevy PRO API key.",
  "type": "module",
  "bin": {
    "hevy-mcp": "dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/sync-versions.mjs && tsc -p tsconfig.json",
    "prepack": "node scripts/sync-versions.mjs && tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "deploy": "wrangler deploy",
    "build:mcpb": "node scripts/sync-versions.mjs && esbuild src/main.ts --bundle --platform=node --format=esm --outfile=mcpb/server/index.js --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\" && mcpb pack mcpb hevy-mcp.mcpb"
  },
  "dependencies": {
    "@almostjacked/hevy-mcp-core": "workspace:*",
    "@hono/mcp": "^0.3.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.31",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "wrangler": "^4.114.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "AJ Wallace <ajwallacemusic@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/almostjacked/hevy-mcp.git",
    "directory": "apps/mcp"
  },
  "mcpName": "io.github.almostjacked/hevy-mcp"
}
